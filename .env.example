# ─── Copiar a .env y rellenar (nunca commitear .env) ───
# cp .env.example .env

# Entorno y servidor
NODE_ENV=development
PORT=3000

# URL pública (enlaces en correos: verificación y descarga de emergencia).
# En producción: https://tu-dominio.com sin barra final.
BASE_URL=http://localhost:3000

# Panel web
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambiar_en_produccion

# Verificación periódica
# Si VERIFICATION_INTERVAL_MINUTES > 0: modo prueba (intervalo en minutos; también desde el panel).
# Si es 0: se usa VERIFICATION_INTERVAL_DAYS.
VERIFICATION_INTERVAL_DAYS=7
VERIFICATION_INTERVAL_MINUTES=0

# Solo si MINUTES=0: cron para comprobar si ya tocó enviar el mail (defecto cada hora).
# Ejemplo solo a las 9:00: VERIFICATION_CRON=0 9 * * *
# VERIFICATION_CRON=0 * * * *
# VERBOSE_VERIFICATION_LOG=true

# Rutas locales (en Docker Compose usar las rutas bajo /app/ que vienen en docker-compose.yml)
DATA_FOLDER=./encrypted_data
DB_PATH=./data/death_switch.db

# Clave para cifrar archivos en disco (los contactos no la necesitan para el ZIP de emergencia)
DECRYPTION_KEY=cambiar_por_una_clave_larga_y_secreta

# Emergencia: caducidad del enlace de descarga (días) y tamaño máximo del ZIP como adjunto (MB)
EMERGENCY_DOWNLOAD_EXPIRY_DAYS=90
EMERGENCY_ZIP_MAX_ATTACH_MB=12

# SMTP
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
# false/0 = sin AUTH (útil con MailHog). Con Gmail suele hacer falta true + usuario/clave.
SMTP_AUTH=false
SMTP_USER=
SMTP_PASS=
# Opcional: remitente visible, ej. "Death Switch <tu_email@gmail.com>"
# SMTP_FROM=

MAIL_TIMEZONE=America/Argentina/Buenos_Aires

# Titular (recibe verificaciones) y contactos de emergencia (coma; espacios opcionales tras la coma)
OWNER_EMAIL=tu_email@gmail.com
CONTACT_EMAILS=contacto1@email.com,contacto2@email.com
